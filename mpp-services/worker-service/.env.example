# =============================================================================
# Worker service — copy to .env
# =============================================================================
# MPP_SECRET_KEY must match judge-service/.env for local two-service demos.

# --- HTTP ---
PORT=4101
# Amount charged per paid request (string, token units depend on MPP / tempo config)
WORKER_CHARGE=0.01

# --- MPP (Tempo mainnet) ---
MPP_SECRET_KEY=replace-with-long-random-hex-use-openssl-rand-hex-32
MPP_USE_TESTNET=false
# Wallet that receives MPP payments (required — server will not start if empty)
MPP_RECIPIENT=0x0000000000000000000000000000000000000000
# TIP-20 used for MPP charges (align with escrow TIP20_STABLECOIN_ADDRESS when possible)
MPP_CURRENCY=0x20c000000000000000000000b9537d11c60e8b50
