# =============================================================================
# Judge service — copy to .env
# =============================================================================
# MPP_SECRET_KEY must match worker-service/.env for local two-service demos.

# --- HTTP ---
PORT=4102
JUDGE_CHARGE=0.02

# --- MPP (Tempo mainnet) ---
MPP_SECRET_KEY=replace-with-long-random-hex-use-openssl-rand-hex-32
MPP_USE_TESTNET=false
# Wallet that receives MPP payments (required — server will not start if empty)
MPP_RECIPIENT=0x0000000000000000000000000000000000000000
MPP_CURRENCY=0x20c000000000000000000000b9537d11c60e8b50

# --- Optional LLM judge (heuristic fallback if unset or API errors) ---
# Public GitHub: keep EMPTY — never commit a real key; each dev sets locally or in host secrets.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=250

# --- Auto-settle on-chain (optional — if both are set, judge calls resolveTask automatically) ---
# Private key of the judge wallet (hex, no 0x prefix). Must match the judge address used in createTask.
JUDGE_PRIVATE_KEY=
# Deployed AgentEscrow contract address. Set after `make deploy-mainnet` in code/.env.
ESCROW_ADDRESS=
TEMPO_RPC_URL=https://rpc.tempo.xyz
